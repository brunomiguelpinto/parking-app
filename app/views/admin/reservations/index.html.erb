<% content_for(:page_heading, "Reservas") %>

<div class="mt-2">
  <p class="text-sm text-gray-500 mb-6">Gere e aprova as reservas de estacionamento</p>
</div>

<% if @pending.any? %>
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4 flex-wrap">
      <h2 class="text-base font-semibold text-gray-900">Pendentes para amanha</h2>
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20"><%= @pending.count %></span>
      <span class="text-sm text-gray-400"><%= Date.tomorrow.strftime("%d/%m/%Y") %></span>
    </div>

    <div class="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      <% @pending.each do |reservation| %>
        <div class="bg-white rounded-2xl border border-gray-100 p-4 sm:p-5">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-sm font-bold text-amber-700 shrink-0">
                <%= reservation.user.name[0].upcase %>
              </div>
              <div class="min-w-0">
                <p class="font-semibold text-gray-900 text-sm truncate"><%= reservation.user.name %></p>
                <p class="text-xs text-gray-400 truncate"><%= reservation.user.email %></p>
              </div>
            </div>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20 shrink-0 ml-2">Pendente</span>
          </div>
          <div class="flex items-center gap-4 text-sm text-gray-600 mb-4 flex-wrap">
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
              <span class="font-semibold">Lugar <%= reservation.parking_spot.name %></span>
            </span>
            <span class="font-mono text-gray-500"><%= reservation.license_plate %></span>
          </div>
          <div class="flex gap-2">
            <%= button_to "Aprovar", approve_admin_reservation_path(reservation), method: :patch, class: "inline-flex items-center justify-center flex-1 px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-xl hover:bg-emerald-700 transition cursor-pointer" %>
            <%= button_to "Rejeitar", reject_admin_reservation_path(reservation), method: :patch, class: "inline-flex items-center justify-center flex-1 px-4 py-2 bg-white text-red-600 text-sm font-semibold rounded-xl border border-red-200 hover:bg-red-50 transition cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div>
  <h2 class="text-base font-semibold text-gray-900 mb-4">Todas as Reservas</h2>
  <% if @all_reservations.any? %>
    <%# Mobile cards %>
    <div class="sm:hidden space-y-3">
      <% @all_reservations.each do |reservation| %>
        <div class="bg-white rounded-2xl border border-gray-100 p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-bold text-gray-900"><%= reservation.date.strftime("%d/%m/%Y") %></span>
            <% case reservation.status %>
            <% when "pending" %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                Pendente
              </span>
            <% when "approved" %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                Aprovada
              </span>
            <% when "rejected" %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-700 ring-1 ring-inset ring-red-600/20">
                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                Rejeitada
              </span>
            <% end %>
          </div>
          <div class="flex items-center gap-2 mb-1">
            <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-500 shrink-0">
              <%= reservation.user.name[0].upcase %>
            </div>
            <span class="text-sm text-gray-700 truncate"><%= reservation.user.name %></span>
          </div>
          <div class="flex items-center gap-3 text-sm mt-2">
            <span class="inline-flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
              <span class="font-semibold text-gray-700"><%= reservation.parking_spot.name %></span>
            </span>
            <span class="font-mono text-gray-500 text-xs"><%= reservation.license_plate %></span>
          </div>
        </div>
      <% end %>
    </div>

    <%# Desktop table %>
    <div class="hidden sm:block bg-white rounded-2xl border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50/50">
              <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Data</th>
              <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Utilizador</th>
              <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Lugar</th>
              <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Matricula</th>
              <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @all_reservations.each do |reservation| %>
              <tr class="hover:bg-gray-50/50 transition duration-150">
                <td class="px-6 py-4 text-sm font-medium text-gray-900 whitespace-nowrap"><%= reservation.date.strftime("%d/%m/%Y") %></td>
                <td class="px-6 py-4 text-sm whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-500">
                      <%= reservation.user.name[0].upcase %>
                    </div>
                    <%= reservation.user.name %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm whitespace-nowrap">
                  <span class="inline-flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
                    <span class="font-semibold"><%= reservation.parking_spot.name %></span>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm font-mono text-gray-500 whitespace-nowrap"><%= reservation.license_plate %></td>
                <td class="px-6 py-4 text-sm whitespace-nowrap">
                  <% case reservation.status %>
                  <% when "pending" %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20">
                      <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                      Pendente
                    </span>
                  <% when "approved" %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                      Aprovada
                    </span>
                  <% when "rejected" %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-700 ring-1 ring-inset ring-red-600/20">
                      <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                      Rejeitada
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl border border-gray-100 py-12 sm:py-16 text-center">
      <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
      </div>
      <p class="text-lg font-semibold text-gray-900">Sem reservas</p>
      <p class="text-sm text-gray-500 mt-1">As reservas aparecerao aqui quando os utilizadores as fizerem.</p>
    </div>
  <% end %>
</div>
