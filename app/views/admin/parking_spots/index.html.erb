<% content_for(:page_heading, "Lugares de Estacionamento") %>

<div class="flex items-center justify-between mb-6 mt-2">
  <p class="text-sm text-gray-500"><%= @parking_spots.count %> lugares configurados</p>
  <%= link_to new_admin_parking_spot_path, class: "inline-flex items-center gap-2 px-4 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl shadow-sm hover:bg-indigo-700 transition" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Novo Lugar
  <% end %>
</div>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
  <% @parking_spots.each do |spot| %>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 text-center <%= spot.active? ? '' : 'opacity-50' %>">
      <div class="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center <%= spot.active? ? 'bg-indigo-50' : 'bg-gray-100' %>">
        <svg class="w-6 h-6 <%= spot.active? ? 'text-indigo-600' : 'text-gray-400' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
      </div>
      <p class="font-bold text-gray-900 text-lg"><%= spot.name %></p>
      <p class="mt-2">
        <% if spot.active? %>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Ativo
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-50 text-gray-600 ring-1 ring-inset ring-gray-500/20">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
            Inativo
          </span>
        <% end %>
      </p>
      <div class="mt-4 pt-3 border-t border-gray-100 flex items-center justify-center gap-3">
        <%= link_to "Editar", edit_admin_parking_spot_path(spot), class: "text-xs font-semibold text-indigo-600 hover:text-indigo-800 transition" %>
        <span class="text-gray-200">|</span>
        <%= button_to spot.active? ? "Desativar" : "Ativar", toggle_admin_parking_spot_path(spot), method: :patch, class: "text-xs font-semibold transition cursor-pointer #{spot.active? ? 'text-red-600 hover:text-red-800' : 'text-emerald-600 hover:text-emerald-800'}" %>
      </div>
    </div>
  <% end %>
</div>
