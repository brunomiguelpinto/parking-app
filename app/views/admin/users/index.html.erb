<% content_for(:page_heading, "Utilizadores") %>

<div class="flex items-center justify-between mb-6 mt-2 gap-3">
  <p class="text-sm text-gray-500"><%= @users.count %> utilizadores</p>
  <%= link_to new_admin_user_path, class: "inline-flex items-center gap-2 px-3 sm:px-4 py-2 sm:py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl shadow-sm hover:bg-indigo-700 transition shrink-0" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" />
    </svg>
    <span class="hidden sm:inline">Novo Utilizador</span>
    <span class="sm:hidden">Novo</span>
  <% end %>
</div>

<%# Mobile cards %>
<div class="sm:hidden space-y-3">
  <% @users.each do |user| %>
    <div class="bg-white rounded-2xl border border-gray-100 p-4">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-sm font-bold text-indigo-600 shrink-0">
          <%= user.name[0].upcase %>
        </div>
        <div class="min-w-0 flex-1">
          <p class="font-semibold text-gray-900 text-sm truncate"><%= user.name %></p>
          <p class="text-xs text-gray-500 truncate"><%= user.email %></p>
        </div>
      </div>
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <% if user.admin? %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-violet-50 text-violet-700 ring-1 ring-inset ring-violet-600/20">Admin</span>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-sky-50 text-sky-700 ring-1 ring-inset ring-sky-600/20">Utilizador</span>
        <% end %>
        <% if user.active? %>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Ativo
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-50 text-gray-600 ring-1 ring-inset ring-gray-500/20">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
            Inativo
          </span>
        <% end %>
      </div>
      <div class="flex items-center gap-3 pt-3 border-t border-gray-100">
        <%= link_to "Editar", edit_admin_user_path(user), class: "text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition" %>
        <% unless user == current_user %>
          <%= button_to user.active? ? "Desativar" : "Ativar", toggle_admin_user_path(user), method: :patch, class: "text-sm font-semibold transition cursor-pointer #{user.active? ? 'text-red-600 hover:text-red-800' : 'text-emerald-600 hover:text-emerald-800'}" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<%# Desktop table %>
<div class="hidden sm:block bg-white rounded-2xl border border-gray-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Utilizador</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Email</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Tipo</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Estado</th>
          <th class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Acoes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-50/50 transition">
            <td class="px-6 py-4 text-sm whitespace-nowrap">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center text-sm font-bold text-indigo-600 shrink-0">
                  <%= user.name[0].upcase %>
                </div>
                <span class="font-semibold text-gray-900"><%= user.name %></span>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap"><%= user.email %></td>
            <td class="px-6 py-4 text-sm whitespace-nowrap">
              <% if user.admin? %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-violet-50 text-violet-700 ring-1 ring-inset ring-violet-600/20">Admin</span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-sky-50 text-sky-700 ring-1 ring-inset ring-sky-600/20">Utilizador</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm whitespace-nowrap">
              <% if user.active? %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  Ativo
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-50 text-gray-600 ring-1 ring-inset ring-gray-500/20">
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                  Inativo
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-right whitespace-nowrap">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Editar", edit_admin_user_path(user), class: "text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition" %>
                <% unless user == current_user %>
                  <%= button_to user.active? ? "Desativar" : "Ativar", toggle_admin_user_path(user), method: :patch, class: "text-sm font-semibold transition cursor-pointer #{user.active? ? 'text-red-600 hover:text-red-800' : 'text-emerald-600 hover:text-emerald-800'}" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
