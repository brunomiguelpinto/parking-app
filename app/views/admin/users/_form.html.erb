<div class="bg-white rounded-2xl border border-gray-100 p-6 max-w-md">
  <%= render "shared/errors", object: user %>

  <%= form_with model: [:admin, user], class: "space-y-5" do |f| %>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nome</label>
      <%= f.text_field :name, class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm bg-gray-50 placeholder-gray-400 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition", autofocus: true %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
      <%= f.email_field :email, class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm bg-gray-50 placeholder-gray-400 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tipo</label>
      <%= f.select :role, [["Utilizador", "user"], ["Administrador", "admin"]], {}, class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1.5"><%= user.new_record? ? "Password" : "Password (deixar vazio para manter)" %></label>
      <%= f.password_field :password, required: user.new_record?, class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm bg-gray-50 placeholder-gray-400 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Confirmar Password</label>
      <%= f.password_field :password_confirmation, required: user.new_record?, class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm bg-gray-50 placeholder-gray-400 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Guardar", class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl shadow-sm hover:bg-indigo-700 transition cursor-pointer" %>
      <%= link_to "Cancelar", admin_users_path, class: "inline-flex items-center px-5 py-2.5 bg-white text-gray-700 text-sm font-semibold rounded-xl border border-gray-300 shadow-sm hover:bg-gray-50 transition" %>
    </div>
  <% end %>
</div>
