<div class="min-h-screen bg-gray-900 flex items-center justify-center px-4 py-8">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="w-14 h-14 sm:w-16 sm:h-16 bg-indigo-500 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-indigo-500/30">
        <svg class="w-8 h-8 sm:w-9 sm:h-9 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white">Parking App</h1>
      <p class="text-sm text-gray-400 mt-2">Entra na tua conta para gerir reservas</p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl p-5 sm:p-7">
      <%= form_with url: login_path, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
          <%= f.email_field :email, autofocus: true, required: true, placeholder: "email@exemplo.com", class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm bg-gray-50 placeholder-gray-400 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
          <%= f.password_field :password, required: true, placeholder: "A tua password", class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm bg-gray-50 placeholder-gray-400 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
        </div>

        <%= f.submit "Entrar", class: "w-full bg-indigo-600 text-white py-3 px-4 rounded-xl text-sm font-semibold hover:bg-indigo-700 active:bg-indigo-800 shadow-sm transition cursor-pointer" %>
      <% end %>
    </div>

    <p class="text-center text-xs text-gray-500 mt-6">Contacta o administrador para obteres uma conta.</p>
  </div>
</div>
