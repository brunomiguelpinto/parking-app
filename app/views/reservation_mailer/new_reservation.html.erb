<div style="font-family: 'Inter', -apple-system, sans-serif; max-width: 480px; margin: 0 auto; padding: 24px;">
  <div style="background: #4f46e5; border-radius: 16px; padding: 24px; text-align: center; margin-bottom: 24px;">
    <h1 style="color: #ffffff; font-size: 18px; margin: 0;">Nova Reserva Pendente</h1>
  </div>

  <div style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 24px; margin-bottom: 16px;">
    <p style="color: #374151; font-size: 14px; margin: 0 0 16px;">
      <strong><%= @user.name %></strong> pediu uma reserva de estacionamento.
    </p>

    <table style="width: 100%; border-collapse: collapse;">
      <tr>
        <td style="padding: 8px 0; color: #6b7280; font-size: 13px; border-bottom: 1px solid #f3f4f6;">Data</td>
        <td style="padding: 8px 0; color: #111827; font-size: 13px; font-weight: 600; text-align: right; border-bottom: 1px solid #f3f4f6;"><%= @reservation.date.strftime("%d/%m/%Y") %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; color: #6b7280; font-size: 13px; border-bottom: 1px solid #f3f4f6;">Lugar</td>
        <td style="padding: 8px 0; color: #111827; font-size: 13px; font-weight: 600; text-align: right; border-bottom: 1px solid #f3f4f6;"><%= @spot.name %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; color: #6b7280; font-size: 13px; border-bottom: 1px solid #f3f4f6;">Matricula</td>
        <td style="padding: 8px 0; color: #111827; font-size: 13px; font-weight: 600; font-family: monospace; text-align: right; border-bottom: 1px solid #f3f4f6;"><%= @reservation.license_plate %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; color: #6b7280; font-size: 13px;">Email</td>
        <td style="padding: 8px 0; color: #111827; font-size: 13px; text-align: right;"><%= @user.email %></td>
      </tr>
    </table>
  </div>

  <div style="text-align: center;">
    <a href="<%= admin_reservations_url %>" style="display: inline-block; background: #4f46e5; color: #ffffff; padding: 12px 32px; border-radius: 12px; text-decoration: none; font-size: 14px; font-weight: 600;">
      Ver Reservas Pendentes
    </a>
  </div>

  <p style="color: #9ca3af; font-size: 11px; text-align: center; margin-top: 24px;">
    Parking App - Reserva de Lugares
  </p>
</div>
