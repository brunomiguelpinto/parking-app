<% if object.errors.any? %>
  <div class="mb-5 p-4 bg-red-50 border border-red-200 rounded-xl text-sm">
    <div class="flex items-center gap-2 text-red-800 font-semibold mb-2">
      <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
      <%= pluralize(object.errors.count, "erro", plural: "erros") %>:
    </div>
    <ul class="list-disc list-inside text-red-700 space-y-0.5">
      <% object.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
