<% content_for(:page_heading, "Dashboard") %>

<%# Stats Cards %>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 mb-6 sm:mb-8 mt-2">
  <div class="bg-white rounded-2xl border border-gray-100 p-4 sm:p-5">
    <div class="flex items-center justify-between">
      <div class="min-w-0">
        <p class="text-sm font-medium text-gray-500">Reserva para amanha</p>
        <% tomorrow_reservation = @reservations.find { |r| r.date == Date.tomorrow } %>
        <% if tomorrow_reservation %>
          <p class="text-xl sm:text-2xl font-bold text-gray-900 mt-1 truncate">Lugar <%= tomorrow_reservation.parking_spot.name %></p>
        <% else %>
          <p class="text-xl sm:text-2xl font-bold text-gray-400 mt-1">--</p>
        <% end %>
      </div>
      <div class="w-10 h-10 sm:w-12 sm:h-12 bg-indigo-50 rounded-xl flex items-center justify-center shrink-0 ml-3">
        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 p-4 sm:p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-500">Total de reservas</p>
        <p class="text-xl sm:text-2xl font-bold text-gray-900 mt-1"><%= @reservations.count %></p>
      </div>
      <div class="w-10 h-10 sm:w-12 sm:h-12 bg-emerald-50 rounded-xl flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 p-4 sm:p-5">
    <div class="flex items-center justify-between">
      <div class="min-w-0">
        <p class="text-sm font-medium text-gray-500">Matricula</p>
        <p class="text-xl sm:text-2xl font-bold text-gray-900 mt-1 font-mono truncate"><%= current_user.license_plate.present? ? current_user.license_plate : '--' %></p>
      </div>
      <div class="w-10 h-10 sm:w-12 sm:h-12 bg-violet-50 rounded-xl flex items-center justify-center shrink-0 ml-3">
        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-violet-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
      </div>
    </div>
  </div>
</div>

<% if !@can_reserve && Time.current.hour < 9 %>
  <div class="mb-6 flex items-center gap-3 p-4 bg-amber-50 border border-amber-200 text-amber-800 rounded-xl text-sm font-medium">
    <svg class="w-5 h-5 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
    </svg>
    As reservas para amanha abrem as 9h da manha.
  </div>
<% end %>

<%# Reservations %>
<div class="flex items-center justify-between mb-5 gap-3">
  <h3 class="text-base font-semibold text-gray-900">As Minhas Reservas</h3>
  <% if @can_reserve %>
    <%= link_to new_reservation_path, class: "inline-flex items-center gap-2 px-3 sm:px-4 py-2 sm:py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl shadow-sm hover:bg-indigo-700 transition shrink-0" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      <span class="hidden sm:inline">Reservar para amanha</span>
      <span class="sm:hidden">Reservar</span>
    <% end %>
  <% end %>
</div>

<% if @reservations.any? %>
  <%# Mobile cards %>
  <div class="sm:hidden space-y-3">
    <% @reservations.each do |reservation| %>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-bold text-gray-900"><%= reservation.date.strftime("%d/%m/%Y") %></span>
          <% case reservation.status %>
          <% when "pending" %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
              Pendente
            </span>
          <% when "approved" %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              Aprovada
            </span>
          <% when "rejected" %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-700 ring-1 ring-inset ring-red-600/20">
              <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
              Rejeitada
            </span>
          <% end %>
        </div>
        <div class="flex items-center gap-3 text-sm">
          <span class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-700 font-semibold rounded-lg text-xs">
            <%= reservation.parking_spot.name %>
          </span>
          <span class="font-mono text-gray-500"><%= reservation.license_plate %></span>
        </div>
      </div>
    <% end %>
  </div>

  <%# Desktop table %>
  <div class="hidden sm:block bg-white rounded-2xl border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Data</th>
            <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Lugar</th>
            <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Matricula</th>
            <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50/80">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @reservations.each do |reservation| %>
            <tr class="hover:bg-gray-50/50 transition">
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= reservation.date.strftime("%d/%m/%Y") %></td>
              <td class="px-6 py-4 text-sm">
                <span class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-700 font-semibold rounded-lg text-xs">
                  <%= reservation.parking_spot.name %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm font-mono text-gray-600"><%= reservation.license_plate %></td>
              <td class="px-6 py-4 text-sm">
                <% case reservation.status %>
                <% when "pending" %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                    Pendente
                  </span>
                <% when "approved" %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    Aprovada
                  </span>
                <% when "rejected" %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-700 ring-1 ring-inset ring-red-600/20">
                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                    Rejeitada
                  </span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="bg-white rounded-2xl border border-gray-100 py-12 sm:py-16 text-center">
    <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
      </svg>
    </div>
    <p class="text-base font-semibold text-gray-900">Sem reservas</p>
    <p class="text-sm text-gray-500 mt-1">Reserva o teu lugar de estacionamento para amanha.</p>
  </div>
<% end %>
